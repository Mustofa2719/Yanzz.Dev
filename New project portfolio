            &copy; 2026 GALAXY.DEV - CODED IN ZERO GRAVITY
        </p>
    </footer>

    <script>
        // --- Background Logic (Canvas JS) ---
        const canvas = document.getElementById('spaceCanvas');
        const ctx = canvas.getContext('2d');
        let stars = [];
        let meteors = [];

        function initCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            stars = [];
            for (let i = 0; i < 200; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    size: Math.random() * 1.5,
                    speed: Math.random() * 0.5,
                    opacity: Math.random()
                });
            }
        }

        function createMeteor() {
            meteors.push({
                x: Math.random() * canvas.width,
                y: -20,
                len: Math.random() * 80 + 50,
                speed: Math.random() * 10 + 5
            });
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = "white";
            stars.forEach(s => {
                ctx.globalAlpha = s.opacity;
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
                ctx.fill();
                s.y += s.speed;
                if (s.y > canvas.height) s.y = 0;
            });

            ctx.strokeStyle = "rgba(255, 255, 255, 0.4)";
            ctx.lineWidth = 1;
            meteors.forEach((m, i) => {
                ctx.beginPath();
                ctx.moveTo(m.x, m.y);
                ctx.lineTo(m.x - m.len, m.y + m.len);
                ctx.stroke();
                m.x -= m.speed;
                m.y += m.speed;
                if (m.y > canvas.height + 100) meteors.splice(i, 1);
            });

            if (Math.random() < 0.01) createMeteor();
            requestAnimationFrame(animate);
        }

        // --- UI Logic ---
        const skills = [
            { name: "Frontend Dev", level: "90%" },
            { name: "Cyber Security", level: "85%" },
            { name: "System Architecture", level: "80%" },
            { name: "C++ Engine Logic", level: "75%" }
        ];

        const projects = [
            { 
                title: "Ghost Keylogger (Arduino)", 
                desc: "Perangkat hardware keylogger berbasis Arduino Micro yang menyamar sebagai keyboard HID untuk audit keamanan fisik.",
                img: "https://images.unsplash.com/photo-1553406830-ef2513450d76?auto=format&fit=crop&q=80&w=800" 
            },
            { 
                title: "Expert Coding Skills", 
                desc: "Menguasai berbagai bahasa pemrograman futuristik termasuk JavaScript, C++, Python, dan integrasi sistem IoT yang aman.",
                img: "https://images.unsplash.com/photo-1515879218367-8466d910aaa4?auto=format&fit=crop&q=80&w=800"
            },
            { 
                title: "Auto-Pwn Drone", 
                desc: "Integrasi Raspberry Pi dengan Kali Linux di atas drone untuk melakukan penetrasi jaringan nirkabel dari jarak jauh secara otomatis.",
                img: "https://images.unsplash.com/photo-1508614589041-895b88991e3e?auto=format&fit=crop&q=80&w=800"
            }
        ];

        function renderUI() {
            const skillContainer = document.getElementById('skillsContainer');
            skillContainer.innerHTML = skills.map(s => `
                <div class="reveal">
                    <div class="flex justify-between mb-1 text-sm font-bold uppercase tracking-widest">
                        <span>${s.name}</span>
                        <span class="text-blue-400">${s.level}</span>
                    </div>
                    <div class="h-1 bg-slate-800 rounded-full overflow-hidden">
                        <div class="h-full bg-blue-500" style="width: ${s.level}"></div>
                    </div>
                </div>
            `).join('');

            const projectGrid = document.getElementById('projectsGrid');
            projectGrid.innerHTML = projects.map(p => `
                <div class="glass p-6 rounded-2xl neon-border hover:-translate-y-2 transition-all reveal">
                    <img src="${p.img}" alt="${p.title}" class="project-img">
                    <h3 class="text-xl font-bold mb-4 text-blue-400 uppercase tracking-tighter">${p.title}</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">${p.desc}</p>
                </div>
            `).join('');
            
            initScrollReveal();
        }

        // --- Scroll Reveal Logic ---
        function initScrollReveal() {
            const reveals = document.querySelectorAll('.reveal, .icon-reveal');
            
            const observerOptions = {
                threshold: 0.1,
                rootMargin: "0px 0px -50px 0px"
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            reveals.forEach(el => observer.observe(el));
        }

        // --- WhatsApp Integration ---
        const contactForm = document.getElementById('contactForm');
        contactForm.onsubmit = (e) => {
            e.preventDefault();
            const name = document.getElementById('senderName').value;
            const email = document.getElementById('senderEmail').value;
            const message = document.getElementById('senderMessage').value;
            const phone = "6282221902355";
            const text = `Halo Galaxy.Dev!\n\nNama: ${name}\nEmail: ${email}\n\nPesan:\n${message}`;
            window.open(`https://wa.me/${phone}?text=${encodeURIComponent(text)}`, '_blank');
        };

        // --- Menu Toggle ---
        const menuBtn = document.getElementById('menuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        menuBtn.onclick = () => mobileMenu.classList.toggle('hidden');
        document.querySelectorAll('.menu-link').forEach(l => {
            l.onclick = () => mobileMenu.classList.add('hidden');
        });

        // --- Init ---
        window.onresize = initCanvas;
        window.onload = () => {
            initCanvas();
            animate();
            renderUI();
        };
    </script>
</body>
</html>